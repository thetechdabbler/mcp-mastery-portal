{
  "name": "mcp-mastery-portal",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "labs/*",
    "challenges/*",
    "packages/*"
  ],
  "scripts": {
    "diagrams": "node scripts/render-diagrams.mjs",
    "predev": "node scripts/install-d2.mjs && node scripts/render-diagrams.mjs",
    "prebuild": "node scripts/install-d2.mjs && node scripts/render-diagrams.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postbuild": "node scripts/build-pagefind.mjs",
    "content:check": "node --import tsx scripts/check-content.ts",
    "challenge": "node --import tsx scripts/run-challenge.ts",
    "smoke:curriculum": "node --import tsx scripts/smoke-curriculum-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.4.2",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@types/unist": "^3.0.3",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "pagefind": "^1.3.0",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "unist-util-visit": "^5.0.0",
    "vitest": "^3.1.4"
  }
}
